---
import Badges from './Badges.astro';

interface IndexRow {
  process_id: string;
  family: string;
  family_original?: string | null;
  tier: string;
  fact_check_verdict?: string | null;
  standard_notation?: string | null;
  process_name?: string | null;
  implementation_difficulty?: string | null;
  code_coverage_status?: string | null;
}

interface Props {
  rows: IndexRow[];
  showFamily?: boolean;
  showOriginalFamily?: boolean;
}

const { rows, showFamily = false, showOriginalFamily = false } = Astro.props as Props;

// Render notation as inline math when it carries any LaTeX command/sub-script.
function inlineMath(s?: string | null): string {
  if (!s) return '';
  const trimmed = s.trim();
  if (!trimmed) return '';
  if (trimmed.startsWith('$') || trimmed.startsWith('\\(')) return trimmed;
  const looksMath = /\\[A-Za-z]+|[\^_]\{|\^\\|\^[A-Za-z0-9]/.test(trimmed);
  return looksMath ? `$${trimmed}$` : trimmed;
}

const FAMILY_LABELS: Record<string, string> = {
  kaon: 'Kaon',
  charm: 'Charm',
  beauty: 'Beauty',
  top_higgs_ew: 'Top/Higgs/EW',
  charged_lepton: 'Charged lepton',
  edm_neutrino: 'EDM/neutrino',
  collider_rs: 'Collider RS',
  secondary: 'Secondary',
};
---
<div class="entry-table-wrap">
<table class="entry-table" data-entry-table>
  <thead>
    <tr>
      <th data-sort="process_id">ID</th>
      <th data-sort="standard_notation">Observable</th>
      {showFamily && <th data-sort="family">Family</th>}
      {showOriginalFamily && <th data-sort="family_original">Origin family</th>}
      <th data-sort="tier">Tier</th>
      <th data-sort="fact_check_verdict">Verdict</th>
      <th data-sort="implementation_difficulty">Difficulty</th>
      <th data-sort="code_coverage_status">Code</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {rows.map((r) => (
      <tr class={r.tier === 'SECONDARY' ? 'row-secondary' : ''}
          data-process-id={r.process_id}
          data-family={r.family}
          data-tier={r.tier}
          data-verdict={(r.fact_check_verdict || '').toUpperCase()}
          data-difficulty={(r.implementation_difficulty || '').toUpperCase()}
          data-coverage={(r.code_coverage_status || '').toUpperCase()}>
        <td>
          <a class="row-id-link" href={`/entries/${r.process_id}/`}>
            <code>{r.process_id}</code>
          </a>
        </td>
        <td class="row-notation">
          <a href={`/entries/${r.process_id}/`}>
            <span set:html={inlineMath(r.standard_notation)}></span>
          </a>
          {r.process_name && <div class="row-process-name">{r.process_name}</div>}
        </td>
        {showFamily && (
          <td><span class="family-chip">{FAMILY_LABELS[r.family] ?? r.family}</span></td>
        )}
        {showOriginalFamily && (
          <td>
            {r.family_original
              ? <span class="family-chip">{FAMILY_LABELS[r.family_original] ?? r.family_original}</span>
              : <span class="row-muted">-</span>}
          </td>
        )}
        <td><Badges kind="tier" value={r.tier} /></td>
        <td><Badges kind="verdict" value={r.fact_check_verdict} /></td>
        <td><Badges kind="difficulty" value={r.implementation_difficulty} /></td>
        <td><Badges kind="coverage" value={r.code_coverage_status} /></td>
        <td class="row-go"><a href={`/entries/${r.process_id}/`} class="row-go-link" aria-label={`Open ${r.process_id}`}>open &rarr;</a></td>
      </tr>
    ))}
  </tbody>
</table>
</div>
