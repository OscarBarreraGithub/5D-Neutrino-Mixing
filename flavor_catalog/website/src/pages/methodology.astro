---
import BaseLayout from '../layouts/BaseLayout.astro';
import index from '../content/catalog_index.json';
import families from '../content/families.json';

/* -----------------------------------------------------------------------
   Methodology -- "How this catalog was built".
   Sleek, inviting, 60-90 second read. Pitches what the catalog is, why
   it can be trusted, and what to do next. Source of truth:
   flavor_catalog/CATALOG_METHODOLOGY.tex. Full pipeline detail lives in
   flavor_catalog/AGENTIC_WORKFLOW.md and is linked, not duplicated.
   ----------------------------------------------------------------------- */

const BRANCH = 'flavor-catalog-website/2026q2';
const GH_REPO = 'https://github.com/OscarBarreraGithub/5D-Neutrino-Mixing';
const GH_BLOB = `${GH_REPO}/blob/${BRANCH}/flavor_catalog`;

const totalEntries: number = index.total_entries;
const verdictCounts: Record<string, number> = index.verdict_counts;
const verified = verdictCounts.VERIFIED ?? 0;
const partial = verdictCounts.PARTIAL ?? 0;
const mismatch = verdictCounts.MISMATCH ?? 0;
const failed = verdictCounts.FAILED ?? 0;

// Citation-anchor resolution: percent of cited values that link back to the
// exact line of the cited source's local snapshot.
const anchorTotals: any = (index as any).anchor_totals ?? null;
const anchorTotal = anchorTotals
  ? (anchorTotals.RESOLVED + anchorTotals.AMBIGUOUS + anchorTotals.UNRESOLVED)
  : 0;
const resolvedPct =
  anchorTotal > 0
    ? ((100 * anchorTotals.RESOLVED) / anchorTotal).toFixed(0)
    : '--';

// Per-family fact-check counts.
type FamRow = {
  key: string;
  label: string;
  total: number;
  verified: number;
  partial: number;
};
const famRows: FamRow[] = (families as any[]).map((fam) => {
  const inFam = (index.entries as any[]).filter((e) => e.family === fam.key);
  const v = inFam.filter((e) => (e.fact_check_verdict || '').toUpperCase() === 'VERIFIED').length;
  const p = inFam.filter((e) => (e.fact_check_verdict || '').toUpperCase() === 'PARTIAL').length;
  return { key: fam.key, label: fam.label, total: fam.count, verified: v, partial: p };
});

const PIPELINE = [
  {
    n: '1',
    title: 'Identify',
    body: 'The project lead seeded the initial list of processes from physics judgment; an independent literature survey then iterated until two consecutive passes found nothing new.',
  },
  {
    n: '2',
    title: 'Draft',
    body: 'For every process, a writer pulls the canonical measurement from PDG, HFLAV, FLAG, or the original collaboration paper and records the value, year, uncertainty, source URL, access date, and a sha256 of a local text snapshot.',
  },
  {
    n: '3',
    title: 'Review',
    body: 'A second, independent reviewer re-runs an 8-item structural checklist on each draft -- every claim must trace to a structured provenance block, every reference must resolve, every status transition must be legal.',
  },
  {
    n: '4',
    title: 'Verify',
    body: 'A separate fact-check pass re-fetches every cited URL with WebFetch and confirms the specific number appears in both the live source and the local snapshot. Five sign-off rounds approved the final catalog.',
  },
];
---

<BaseLayout
  title="How this catalog was built -- Flavor Catalog"
  description="How the 102-entry flavor-physics catalog was built: an Identify / Draft / Review / Verify pipeline with full provenance and exact-source linking."
>
  <section class="meth-hero">
    <div class="breadcrumbs"><a href="/">Catalog</a> &middot; Methodology</div>
    <h1>How this catalog was built</h1>
    <p class="meth-lede">
      A catalog of <strong>{totalEntries} flavor-physics constraints</strong>
      on the Randall&ndash;Sundrum scan, with full provenance. Every claim
      links back to the exact line of the cited source &mdash; this is not a
      bibliography, it's a verifiable inventory.
    </p>
  </section>

  <aside class="meth-scope honesty-note" set:html={`
    <strong>Scope, honestly.</strong> Low-energy flavor constraints dominate
    the catalog and push the warped KK scale to
    $M_{KK}^{\\min,\\,p_{50}}(g_\\ast = 3) \\approx 47~\\text{TeV}$ in the
    repo's quark scan. Direct collider searches reach only the few-TeV scale
    and are shown alongside, not as the leading bound.
  `}></aside>

  <section class="entry-section">
    <h2>The pipeline</h2>
    <p class="meth-sub">
      Four stages, applied uniformly to every entry. The Draft and Review
      stages are always run by independent reviewers on the same batch &mdash;
      the writer never checks their own work.
    </p>
    <ol class="pipeline-grid">
      {PIPELINE.map((s) => (
        <li class="pipeline-card">
          <span class="pipeline-num">{s.n}</span>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="entry-section">
    <h2>Trust at a glance</h2>
    <p>
      Independent fact-check verdicts across all {totalEntries} entries.
      Of the {anchorTotal} cited values stamped with a source-line anchor,
      <strong>about {resolvedPct}%</strong> link to the exact line of the
      cited source's local snapshot; the remainder are flagged
      <em>ambiguous</em> or <em>unresolved</em> rather than hidden, so a
      reader always knows what was matched and what was not.
    </p>
    <div class="entry-table-wrap">
      <table class="entry-table methodology-fc-table">
        <thead>
          <tr>
            <th>Family</th>
            <th>Entries</th>
            <th>Verified</th>
            <th>Partial</th>
          </tr>
        </thead>
        <tbody>
          {famRows.map((r) => (
            <tr>
              <td><a href={`/families/${r.key}/`}>{r.label}</a></td>
              <td>{r.total}</td>
              <td><span class="badge badge-verified">{r.verified}</span></td>
              <td>{r.partial > 0
                ? <span class="badge badge-partial">{r.partial}</span>
                : <span class="row-muted">0</span>}</td>
            </tr>
          ))}
          <tr class="fc-total">
            <td><strong>Total</strong></td>
            <td><strong>{totalEntries}</strong></td>
            <td><strong>{verified}</strong></td>
            <td><strong>{partial}</strong></td>
          </tr>
        </tbody>
      </table>
    </div>
    {(mismatch > 0 || failed > 0) && (
      <p class="evidence-cap">
        Mismatch: {mismatch}. Failed: {failed}.
      </p>
    )}
    <p class="meth-partial-note">
      <strong>The single partial.</strong> One of {totalEntries} entries
      (the Weinberg three-gluon operator, E009) is marked PARTIAL: the
      fact-check tool couldn't reach an INSPIRE metadata page that renders
      via JavaScript only. The underlying numerical value was independently
      verified against the publisher (APS) and the local snapshot, so no
      value-bearing claim is in doubt.
    </p>
  </section>

  <section class="entry-section">
    <h2>What you can do</h2>
    <ul class="meth-next-list">
      <li>
        <a href="/browse/"><strong>Browse the full inventory</strong></a> &mdash;
        filter by family, search by process, sort by status.
      </li>
      <li>
        <strong>Start with a worked example.</strong> See
        <a href="/entries/K001/">indirect CP violation in neutral-kaon mixing</a>
        for a low-energy flavor entry, or
        <a href="/entries/CR002/">pair-production of custodial top partners</a>
        for a direct-collider entry.
      </li>
      <li>
        <strong>Go deeper.</strong> The
        <a href={`${GH_BLOB}/CATALOG_METHODOLOGY.tex`}>methodology one-pager</a>
        and the full
        <a href={`${GH_BLOB}/catalog_master.pdf`}>catalog PDF (v0.4, 179 pp.)</a>
        give the long-form version; everything lives in the
        <a href={GH_REPO}>source repository</a>.
      </li>
    </ul>
  </section>

  <div class="hero-ctas meth-final-ctas">
    <a class="hero-cta hero-cta-primary" href="/browse/">Browse all {totalEntries} entries &rarr;</a>
    <a class="hero-cta" href="/">Back to catalog</a>
  </div>

  <p class="meth-footnote">
    A small number of drafts were arbitrated where reviewers disagreed; the
    full sign-off and arbitration history is documented in the
    <a href={`${GH_BLOB}/signoff/`}>sign-off worklogs</a>. The catalog is
    version-tagged (current: <code>flavor-catalog-v0.4</code>).
  </p>
</BaseLayout>

<style>
.meth-hero {
  margin: 2.25rem 0 1rem;
}
.meth-hero .breadcrumbs {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  margin-bottom: 0.45rem;
}
.meth-hero h1 {
  font-size: 2rem;
  line-height: 1.15;
  letter-spacing: -0.015em;
  margin: 0 0 0.6rem;
}
.meth-lede {
  margin: 0;
  font-size: 1.05rem;
  color: var(--color-text-muted);
  max-width: 62ch;
  line-height: 1.55;
}
.meth-lede strong { color: var(--color-text); }

.meth-scope {
  margin-top: 1.5rem;
  margin-bottom: 2rem;
}

.meth-sub {
  color: var(--color-text-muted);
  margin: 0 0 1rem;
  max-width: 70ch;
}

.pipeline-grid {
  list-style: none;
  padding: 0;
  margin: 0.75rem 0 0;
  display: grid;
  gap: 0.9rem;
  grid-template-columns: repeat(4, 1fr);
}
.pipeline-card {
  position: relative;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1rem 1rem 1.1rem;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.pipeline-num {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  display: inline-flex;
  width: 1.65rem;
  height: 1.65rem;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: var(--color-accent-soft);
  color: var(--color-accent);
}
.pipeline-card h3 {
  margin: 0;
  font-size: 1rem;
  letter-spacing: -0.005em;
  color: var(--color-text);
}
.pipeline-card p {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.5;
  color: var(--color-text-muted);
}

@media (max-width: 880px) {
  .pipeline-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 520px) {
  .pipeline-grid { grid-template-columns: 1fr; }
  .meth-hero h1 { font-size: 1.55rem; }
  .meth-lede { font-size: 0.98rem; }
}

.methodology-fc-table {
  min-width: 420px;
}
.methodology-fc-table .row-muted {
  color: var(--color-text-muted);
}
.fc-total td {
  background: var(--color-surface-2);
  border-top: 2px solid var(--color-border-strong);
}

.meth-partial-note {
  margin: 1rem 0 0;
  padding: 0.85rem 1rem;
  background: var(--color-surface);
  border-left: 3px solid var(--badge-partial-fg);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 0.93rem;
  line-height: 1.55;
}
.meth-partial-note strong { color: var(--badge-partial-fg); }

.meth-next-list {
  list-style: none;
  padding: 0;
  margin: 0.5rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}
.meth-next-list li {
  padding: 0.7rem 0.9rem;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: 0.95rem;
  line-height: 1.55;
}

.meth-final-ctas {
  margin-top: 2rem;
}

.meth-footnote {
  margin-top: 2rem;
  font-size: 0.82rem;
  color: var(--color-text-muted);
  line-height: 1.5;
}
</style>