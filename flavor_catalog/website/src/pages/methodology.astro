---
import BaseLayout from '../layouts/BaseLayout.astro';
import index from '../content/catalog_index.json';
import families from '../content/families.json';

/* -----------------------------------------------------------------------
   Methodology, "How we built this and why you can trust it".
   Sells the citation-exact provenance pitch, then backs it with two
   concrete trust indicators: per-family fact-check counts and the
   citation-anchor resolution rate.  No internal vocabulary.
   ----------------------------------------------------------------------- */

const totalEntries: number = index.total_entries;
const verdictCounts: Record<string, number> = index.verdict_counts;
const verified = verdictCounts.VERIFIED ?? 0;
const partial = verdictCounts.PARTIAL ?? 0;
const mismatch = verdictCounts.MISMATCH ?? 0;
const failed = verdictCounts.FAILED ?? 0;

// Citation-anchor resolution: percent of cited values that link back to the
// exact line of the cited source's local snapshot.
const anchorTotals: any = (index as any).anchor_totals ?? null;
const resolvedCount = anchorTotals?.RESOLVED ?? 0;
const anchorTotal = anchorTotals
  ? (anchorTotals.RESOLVED + anchorTotals.AMBIGUOUS + anchorTotals.UNRESOLVED)
  : 0;
const resolvedPct =
  anchorTotal > 0
    ? ((100 * anchorTotals.RESOLVED) / anchorTotal).toFixed(0)
    : '--';

// Per-family fact-check counts.
type FamRow = {
  key: string;
  label: string;
  total: number;
  verified: number;
  partial: number;
};
const famRows: FamRow[] = (families as any[]).map((fam) => {
  const inFam = (index.entries as any[]).filter((e) => e.family === fam.key);
  const v = inFam.filter((e) => (e.fact_check_verdict || '').toUpperCase() === 'VERIFIED').length;
  const p = inFam.filter((e) => (e.fact_check_verdict || '').toUpperCase() === 'PARTIAL').length;
  return { key: fam.key, label: fam.label, total: fam.count, verified: v, partial: p };
});

// Pipeline cards: describe the quality guarantee at each stage, in plain
// English.  No internal stage names.
const PIPELINE = [
  {
    n: '1',
    title: 'Selected on purpose',
    body: 'Every process was chosen because it actually constrains the model, not as a survey item. The list was first drafted from physics judgment, then iterated against the literature until two consecutive sweeps found nothing new to add.',
  },
  {
    n: '2',
    title: 'Written from primary sources',
    body: 'Each entry was authored from scratch by a writer working from the canonical reference (PDG, HFLAV, FLAG, or the original collaboration paper). Every value carries its source URL, an access date, a sha256 of a local text snapshot, and the published uncertainty.',
  },
  {
    n: '3',
    title: 'Reviewed independently',
    body: 'A second reader, not the writer, re-checked each draft against an eight-item structural checklist: every claim must trace to its provenance block, every reference must resolve, every recorded status transition must be legal.',
  },
  {
    n: '4',
    title: 'Verified line by line',
    body: 'An automated fact-check tool re-fetched every cited URL and confirmed that the specific number from the entry appears in both the live page and the local snapshot. The 644 source-line anchors you can open from "view in source" came out of this pass.',
  },
];
---

<BaseLayout
  title="How we built this and why you can trust it"
  description="How the 102-entry flavor-physics catalog was built: every numerical claim links to the exact line of the cited source, with sha256-verified local snapshots and an independent fact-check pass."
>
  <section class="meth-hero">
    <div class="breadcrumbs"><a href="/">Catalog</a> &middot; Methodology</div>
    <h1>How we built this, and why you can trust it.</h1>
    <p class="meth-lede">
      Most reviews give you a number and a citation. This one gives you the
      number, the citation, the local sha256-stamped snapshot, and the exact
      line of that snapshot where the value lives. Click <strong>"view in
      source"</strong> on any value in any entry, and the modal opens to the
      cited line, highlighted, with the publisher URL beside it.
    </p>
    <p class="meth-lede">
      That is the only claim this page is making: every numerical statement
      in the catalog is traceable, by a reader, in one click, to a fixed text
      anchor in a fixed snapshot of a published source.
    </p>
  </section>

  <section class="entry-section">
    <h2>How an entry gets in</h2>
    <p class="meth-sub">
      Four stages, applied uniformly to every entry. Writing and reviewing
      are done by different people on the same batch, so a writer never
      checks their own work.
    </p>
    <ol class="pipeline-grid">
      {PIPELINE.map((s) => (
        <li class="pipeline-card">
          <span class="pipeline-num">{s.n}</span>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
        </li>
      ))}
    </ol>
  </section>

  <section class="entry-section">
    <h2>What you can actually check</h2>
    <p>
      Across the whole catalog, the source-line check resolved
      <strong>{resolvedCount} of {anchorTotal}</strong> cited values
      directly to the line of the snapshot where the number appears
      ({resolvedPct}%). The rest are flagged <em>ambiguous</em> or
      <em>unresolved</em> in the same UI, never hidden, so the reader always
      knows which values were matched automatically and which need a manual
      look.
    </p>
    <p class="meth-example" set:html={`
      <strong>Concretely:</strong> the indirect CP-violation entry
      (<a href="/entries/K001/">K001</a>) cites
      $|\\varepsilon_K| = 2.228 \\times 10^{-3}$ from the PDG 2024 review.
      Opening "view in source" jumps to the exact line of the local PDG
      snapshot containing that value, side by side with the publisher URL
      and the sha256 of the snapshot. The same is true of the
      $\\Delta m_s = 17.766~\\text{ps}^{-1}$ HFLAV average in
      <a href="/entries/B003/">B003</a> and every other numerical claim in
      the catalog.
    `}></p>

    <div class="entry-table-wrap">
      <table class="entry-table methodology-fc-table">
        <thead>
          <tr>
            <th>Family</th>
            <th>Entries</th>
            <th>Verified</th>
            <th>Partial</th>
          </tr>
        </thead>
        <tbody>
          {famRows.map((r) => (
            <tr>
              <td><a href={`/families/${r.key}/`}>{r.label}</a></td>
              <td>{r.total}</td>
              <td><span class="badge badge-verified">{r.verified}</span></td>
              <td>{r.partial > 0
                ? <span class="badge badge-partial">{r.partial}</span>
                : <span class="row-muted">0</span>}</td>
            </tr>
          ))}
          <tr class="fc-total">
            <td><strong>Total</strong></td>
            <td><strong>{totalEntries}</strong></td>
            <td><strong>{verified}</strong></td>
            <td><strong>{partial}</strong></td>
          </tr>
        </tbody>
      </table>
    </div>
    {(mismatch > 0 || failed > 0) && (
      <p class="evidence-cap">
        Mismatch: {mismatch}. Failed: {failed}.
      </p>
    )}
    <p class="meth-partial-note">
      <strong>The one PARTIAL entry.</strong> A single entry of {totalEntries}
      (the Weinberg three-gluon operator, <a href="/entries/E009/">E009</a>)
      is marked PARTIAL because the fact-check tool could not read one
      JavaScript-rendered INSPIRE metadata page. The underlying value was
      independently confirmed against the publisher (APS) and the local
      snapshot, so no value-bearing claim is in doubt. We flag the gap rather
      than paper over it.
    </p>
  </section>

  <section class="entry-section">
    <h2>What it cannot do</h2>
    <p>
      This catalog is a verified inventory of constraints, not an
      end-to-end re-derivation. The fact-check confirms that what we say a
      reference says, that reference does say. It does not re-derive Wilson
      coefficients, re-fit lattice inputs, or re-evaluate hadronic matrix
      elements. If a published value is later revised, the entry needs to
      be re-snapshotted to track the update; the sha256 stamp makes that
      obvious.
    </p>
  </section>

  <div class="hero-ctas meth-final-ctas">
    <a class="hero-cta hero-cta-primary" href="/browse/">Browse all {totalEntries} entries &rarr;</a>
    <a class="hero-cta" href="/">Back to the catalog</a>
  </div>

  <p class="meth-footnote">
    The catalog is version-tagged at <code>flavor-catalog-v0.4</code> in the
    source repository.
  </p>
</BaseLayout>

<style>
.meth-hero {
  margin: 2.25rem 0 1rem;
}
.meth-hero .breadcrumbs {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  margin-bottom: 0.45rem;
}
.meth-hero h1 {
  font-size: 2rem;
  line-height: 1.15;
  letter-spacing: -0.015em;
  margin: 0 0 0.6rem;
}
.meth-lede {
  margin: 0 0 0.8rem;
  font-size: 1.05rem;
  color: var(--color-text-muted);
  max-width: 62ch;
  line-height: 1.55;
}
.meth-lede:last-child { margin-bottom: 0; }
.meth-lede strong { color: var(--color-text); }

.meth-sub {
  color: var(--color-text-muted);
  margin: 0 0 1rem;
  max-width: 70ch;
}

.meth-example {
  margin: 1rem 0;
  padding: 0.85rem 1rem;
  background: var(--color-surface);
  border-left: 3px solid var(--color-accent);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 0.95rem;
  line-height: 1.6;
  color: var(--color-text);
}
.meth-example strong { color: var(--color-accent); }

.pipeline-grid {
  list-style: none;
  padding: 0;
  margin: 0.75rem 0 0;
  display: grid;
  gap: 0.9rem;
  grid-template-columns: repeat(4, 1fr);
}
.pipeline-card {
  position: relative;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 1rem 1rem 1.1rem;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.pipeline-num {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  display: inline-flex;
  width: 1.65rem;
  height: 1.65rem;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: var(--color-accent-soft);
  color: var(--color-accent);
}
.pipeline-card h3 {
  margin: 0;
  font-size: 1rem;
  letter-spacing: -0.005em;
  color: var(--color-text);
}
.pipeline-card p {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.5;
  color: var(--color-text-muted);
}

@media (max-width: 880px) {
  .pipeline-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 520px) {
  .pipeline-grid { grid-template-columns: 1fr; }
  .meth-hero h1 { font-size: 1.55rem; }
  .meth-lede { font-size: 0.98rem; }
}

.methodology-fc-table {
  min-width: 420px;
}
.methodology-fc-table .row-muted {
  color: var(--color-text-muted);
}
.fc-total td {
  background: var(--color-surface-2);
  border-top: 2px solid var(--color-border-strong);
}

.meth-partial-note {
  margin: 1rem 0 0;
  padding: 0.85rem 1rem;
  background: var(--color-surface);
  border-left: 3px solid var(--badge-partial-fg);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 0.93rem;
  line-height: 1.55;
}
.meth-partial-note strong { color: var(--badge-partial-fg); }

.meth-final-ctas {
  margin-top: 2rem;
}

.meth-footnote {
  margin-top: 2rem;
  font-size: 0.82rem;
  color: var(--color-text-muted);
  line-height: 1.5;
}
</style>
