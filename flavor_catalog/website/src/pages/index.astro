---
import BaseLayout from '../layouts/BaseLayout.astro';
import families from '../content/families.json';
import index from '../content/catalog_index.json';

const totalEntries: number = index.total_entries;
const verdictCounts: Record<string, number> = index.verdict_counts;
const verified = verdictCounts.VERIFIED ?? 0;
const partial = verdictCounts.PARTIAL ?? 0;
const mismatch = verdictCounts.MISMATCH ?? 0;

// Compute primary/secondary from family_counts: secondary family is the only SECONDARY tier family
const familyCounts: Record<string, number> = (index as any).family_counts ?? {};
const secondaryCount: number = familyCounts.secondary ?? 8;
const primaryCount: number = totalEntries - secondaryCount;

const anchorTotals: any = (index as any).anchor_totals ?? null;
const anchorTotal = anchorTotals
  ? (anchorTotals.RESOLVED + anchorTotals.AMBIGUOUS + anchorTotals.UNRESOLVED)
  : 0;
---
<BaseLayout
  title="Flavor Catalog -- 5D Neutrino Mixing"
  description="Static catalog of 102 flavor-physics process entries supporting the 5D / RS warped-extra-dimension scan."
>
  <section class="hero">
    <h1>Flavor catalog for the 5D&hairsp;/&hairsp;RS scan</h1>
    <p>
      A snapshot of {totalEntries} flavor-physics processes that constrain &mdash; or could constrain &mdash;
      the anarchic-flavor Randall&ndash;Sundrum scan in this repository.
    </p>
  </section>

  <div class="hero-ctas">
    <a class="hero-cta hero-cta-primary" href="/browse/">Browse all {totalEntries} entries &rarr;</a>
    <a class="hero-cta" href="/methodology/">How this catalog was built &rarr;</a>
  </div>

  <div class="catalog-stats-strip">
    <span>{primaryCount} primary</span>
    <span class="stats-sep">&middot;</span>
    <span>{secondaryCount} secondary</span>
    <span class="stats-sep">&middot;</span>
    <span>{verified} verified</span>
    {partial > 0 && <><span class="stats-sep">&middot;</span><span>{partial} partial</span></>}
    {mismatch > 0 && <><span class="stats-sep">&middot;</span><span>{mismatch} mismatch</span></>}
    {anchorTotal > 0 && (
      <>
        <span class="stats-sep">&middot;</span>
        <span>{anchorTotal} citation anchors</span>
      </>
    )}
  </div>

  <h2 class="section-eyebrow">Families</h2>
  <div class="family-grid">
    {families.map((fam) => (
      <a class="family-card" href={`/families/${fam.key}/`}>
        <h2>
          <span>{fam.label}</span>
          <span class="count">{fam.count}</span>
        </h2>
        <p>{fam.descriptor}</p>
      </a>
    ))}
  </div>

  <aside class="honesty-note" set:html={`
    <strong>Scope note.</strong> Low-energy flavor families (kaon, beauty,
    charm, EDM/neutrino) imply
    $M_{KK}^{\\min,\\,p_{50}}(g_\\ast = 3) \\approx 47.26~\\text{TeV}$
    in the repo-local rc1.1 quark scan, while the
    <code>collider_rs</code> Wave-9 direct-search reach for custodial
    top-partners and KK gauge resonances sits near the few-TeV scale.
    Direct LHC limits and indirect flavor bounds therefore probe qualitatively
    different mass scales and should not be mapped onto a single
    $M_{KK}$ axis without explicit model assumptions.
    See the <a href="/methodology/">methodology page</a> for details.
  `}></aside>
</BaseLayout>
